    {
      "parameters": {
        "options": {
          "delimiter": ";",
          "encoding": "utf-8",
          "headerRow": true
        }
      },
      "id": "e743b5ac-f004-4aea-b09c-497570ae4ebf",
      "name": "Parse stundenauswertung CSV",
      "type": "n8n-nodes-base.extractFromFile",
      "typeVersion": 1.1,
      "position": [
        848,
        192
      ]
    },
    {
      "parameters": {
        "jsCode": "const parseGermanNumber = (val) => {\n  if (!val || val === '' || val === '-') return null;\n  const cleaned = String(val).replace(/\\./g, '').replace(',', '.');\n  const num = parseFloat(cleaned);\n  return isNaN(num) ? null : num;\n};\n\nconst normalizeColumnName = (name) => {\n  return name\n    .toLowerCase()\n    .trim()\n    .replace(/\\(/g, '_')\n    .replace(/\\)/g, '')\n    .replace(/\\//g, '_')\n    .replace(/-/g, '_')\n    .replace(/\\./g, '_')\n    .replace(/\\s+/g, '_')\n    .replace(/_+/g, '_')\n    .replace(/^_|_$/g, '');\n};\n\nconst matchingColumnsMap = {\n  'Tag': 'tag',\n  'Mitarbeiter': 'mitarbeiter',\n  'Personalnummer': 'personalnummer',\n  'Lohnart Bezeichnung': 'lohnart_bezeichnung',\n  'Lohnart Nr.': 'lohnart_nr',\n  'Produktivität': 'produktivitaet',\n  'Vorgang/Projektakte': 'vorgang_projektakte',\n  'Vorgangsnummer': 'vorgangsnummer',\n  'Vorgang-/Projekttyp': 'vorgang_projekttyp',\n  'Arbeitszeit': 'arbeitszeit',\n  'Pausenzeit': 'pausenzeit',\n  'Satz': 'satz',\n  'Summe Satz': 'summe_satz',\n  'Ende-Datum': 'ende_datum',\n  'Von-Zeit': 'von_zeit',\n  'Bis-Zeit': 'bis_zeit',\n  'Buchungskategorie': 'buchungskategorie',\n  'Meldungstyp': 'meldungstyp',\n  'Meldungstext': 'meldungstext',\n  'KST/KTR': 'kst_ktr',\n  'Bemerkung': 'bemerkung',\n  'Dokumente': 'dokumente',\n  'Aufschlag': 'aufschlag',\n  'Aufschlag Summe': 'aufschlag_summe',\n  'Gesamtwert': 'gesamtwert',\n  'Person': 'person',\n  'Kunden-/Lieferantennummer': 'kunden_lieferantennummer',\n  'Gerät': 'geraet',\n  'Wochentag': 'wochentag',\n  'Betrag': 'betrag',\n  'Prozent': 'prozent',\n  'Faktor': 'faktor',\n  'Summe Faktor': 'summe_faktor',\n  'Menge': 'menge',\n  'Zeitabzug(min)': 'zeitabzugmin',\n  'Tätigkeit': 'tatigkeit'\n};\n\nconst rows = $input.all();\nconst allCleaned = [];\n\nfor (const item of rows) {\n  const r = item.json;\n  const mapped = {};\n  for (const [key, val] of Object.entries(r)) {\n    if (key === '' || key === ' |-') continue;\n    const mappedKey = matchingColumnsMap[key];\n    const k = mappedKey || normalizeColumnName(key);\n    mapped[k] = val;\n  }\n  allCleaned.push(mapped);\n}\n\nlet lastTag = null;\nconst filtered = [];\nfor (const row of allCleaned) {\n  const tagVal = row.tag;\n  const isSubtotal = tagVal && !row.personalnummer;\n  \n  if (isSubtotal) {\n    lastTag = tagVal;\n    continue;\n  }\n  \n  if (!row.tag && lastTag) {\n    row.tag = lastTag;\n  }\n  \n  filtered.push(row);\n}\n\nconst numericFields = ['arbeitszeit','pausenzeit','zeitabzugmin','satz','summe_satz','faktor','summe_faktor','gesamtwert','betrag','aufschlag','aufschlag_summe','menge','prozent'];\nfiltered.forEach(f => {\n  numericFields.forEach(field => {\n    if (f[field] != null) f[field] = parseGermanNumber(f[field]);\n  });\n});\n\nreturn filtered;"
      },
