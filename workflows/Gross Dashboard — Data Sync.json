    {
      "parameters": {
        "jsCode": "function parseGermanDateTime(val) {\n  if (!val || val === '' || val === '-') return null;\n  const s = String(val).trim();\n  const m = s.match(/^(\\d{2})\\.(\\d{2})\\.(\\d{4})(?:\\s+(\\d{2}):(\\d{2}))?$/);\n  if (!m) return null;\n  const [, day, month, year, hour, minute] = m;\n  let iso = `${year}-${month}-${day}`;\n  if (hour !== undefined && minute !== undefined) {\n    iso += `T${hour}:${minute}:00`;\n    } else {\n    iso += 'T00:00:00';\n    }\n  return iso;\n}\n\nconst normalizeColumnName = (name) => {\n  return name\n      .toLowerCase()\n      .trim()\n      .replace(/\\u00f6/g, 'oe')\n      .replace(/\\u00e4/g, 'ae')\n      .replace(/\\u00fc/g, 'ue')\n      .replace(/\\u00df/g, 'ss')\n      .replace(/\\//g, '_')\n      .replace(/\\(/g, '')\n      .replace(/\\)/g, '')\n      .replace(/-/g, '_')\n      .replace(/\\./g, '_')\n      .replace(/\\s+/g, '_')\n      .replace(/_+/g, '_')\n      .replace(/^_|_$/g, '');\n};\n\nconst columnMap = {\n    'Terminbezeichnung': 'terminbezeichnung',\n    'Terminbeschreibung': 'terminbeschreibung',\n    'Von': 'von',\n    'Bis': 'bis',\n    'Status': 'status',\n    'Personalnummer': 'personalnummer',\n    'Mitarbeiter': 'mitarbeiter',\n    'Dauer(h:min)': 'dauer',\n    'Fix': 'fix',\n    'Geschäftspartner': 'geschaeftspartner',\n    'Einsatzort': 'einsatzort',\n    'Vorgang/Projekt Bezeichnung': 'vorgang_projekt_bezeichnung',\n    'Vorgang/Projekt Nummer': 'vorgang_projekt_nummer',\n    'Vorgang/Projekt Typ': 'vorgang_projekt_typ'\n};\n\nconst rows = $input.all();\nconst result = [];\n\nfor (const item of rows) {\n  const r = item.json;\n  const mapped = {};\n\n  const fn = String(r.fileName || '').toLowerCase();\n  if (fn.includes('projekt') && !fn.includes('stundenauswertung')) {\n    mapped.file_type = 'projekt';\n    } else if (fn.includes('urlaub')) {\n    mapped.file_type = 'urlaub';\n    } else if (fn.includes('stoerung')) {\n    mapped.file_type = 'stoerung';\n    } else if (fn.includes('freier termin')) {\n    mapped.file_type = 'freier_termin';\n    } else {\n    mapped.file_type = 'unknown';\n    }\n\n  for (const [key, val] of Object.entries(r)) {\n    if (key === '' || key === 'fileName' || key === 'data' || key === 'mimeType') continue;\n    const mappedKey = columnMap[key] || normalizeColumnName(key);\n    const v = typeof val === 'string' ? val.trim() : val;\n\n    if (mappedKey === 'von' || mappedKey === 'bis') {\n      mapped[mappedKey] = parseGermanDateTime(v);\n      } else if (mappedKey === 'fix') {\n      mapped[mappedKey] = v === 'ja' ? true : v === 'nein' ? false : null;\n      } else if (mappedKey === 'personalnummer') {\n      mapped[mappedKey] = v === '<diverse>' ? null : (v === '' || v === '-' ? null : v);\n      } else {\n      mapped[mappedKey] = v === '' || v === '-' ? null : v;\n      }\n    }\n\n  result.push(mapped);\n}\n\nreturn result;"
      },
